      "side_effect_level": "read",
      "execution_mode": "com_worker",
      "requires_human_approval": false,
      "input_schema": {
        "type": "object",
        "properties": {
          "folder": {"type": "string"},
          "days": {"type": "integer"},
          "query": {"type": "string"},
          "max_results": {"type": "integer"}
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "messages": {"type": "array"}
        }
      },
      "allowed_for_agent_types": ["task_control_agent", "meeting_agent"],
      "examples": [
        "Найти письма за последние 7 дней",
        "Найти письма со словами поручение, выполнить, подготовить"
      ],
      "planner_hint": "Безопасное read-действие. Можно использовать для поиска писем за период. Используй, когда нужно найти письма, которые могут содержать поручения, договорённости, согласования или входящие данные."
    },
