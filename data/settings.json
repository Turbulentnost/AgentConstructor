{
  "app_name": "Конструктор ИИ-агентов",
  "run_mode": "outlook_readonly",
  "agent_build_mode": "llm_agent_loop",
  "database_path": "./data/agents.db",
  "tools_catalog_path": null,
  "use_llm_planner": true,
  "llm_provider": "anthropic",
  "llm_base_url": "https://api.anthropic.com",
  "llm_model_name": "claude-sonnet-4-6",
  "llm_temperature": 0.2,
  "llm_timeout_seconds": 120,
  "com_safe_mode": true,
  "com_worker_timeout_seconds": 60,
  "outlook_mail_days": 7,
  "outlook_mail_max_results": 10,
  "outlook_calendar_days_forward": 7,
  "outlook_calendar_max_results": 10
}
